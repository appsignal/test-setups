{
    "name": "appsignal/vanilla-php",
    "type": "project",
    "description": "Vanilla PHP application with OpenTelemetry and AppSignal",
    "require": {
        "php": "^8.4",
        "appsignal/appsignal-php": "*@dev",
        "nyholm/psr7": "^1.8",
        "symfony/http-client": "^7.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../integration",
            "options": {
                "symlink": true
            }
        }
    ],
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true,
            "tbachert/spi": false
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
