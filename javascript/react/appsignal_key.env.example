# Front-end (browser) AppSignal key for the @appsignal/javascript integration.
# This is NOT a backend push API key; it is the app's separate front-end API key,
# found under the app's settings in AppSignal. commands/run re-exports it under the
# prefix this app's bundler requires (VITE_/REACT_APP_), so you only set this one var.
# Copy this file to `appsignal_key.env` and fill in your key:
#   cp appsignal_key.env.example appsignal_key.env
APPSIGNAL_FRONTEND_API_KEY=example
