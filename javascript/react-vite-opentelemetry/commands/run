#!/bin/bash
set -eu

cd /app

# The front-end API key comes from the setup's app-local appsignal_key.env
# (APPSIGNAL_FRONTEND_API_KEY), loaded via docker-compose env_file. Fail with a
# clear message if it is unset, rather than building a bundle with no key.
if [ -z "${APPSIGNAL_FRONTEND_API_KEY:-}" ]; then
  echo "APPSIGNAL_FRONTEND_API_KEY not set. Copy appsignal_key.env.example to appsignal_key.env and set it (see README)."
  exit 1
fi

echo "Install dependencies"
# using `--force` because the `@opentelemetry/react-load-plugin`
# package expects React 16, but we're using React 19.
npm install --force

# Vite only exposes VITE_-prefixed variables to the bundle, so re-export the
# canonical front-end key under the VITE_ name the app reads. The app source and
# Vite config are untouched.
export VITE_APPSIGNAL_FRONTEND_PUSH_API_KEY="$APPSIGNAL_FRONTEND_API_KEY"
export VITE_APPSIGNAL_APP_NAME="$APPSIGNAL_APP_NAME"
export VITE_APPSIGNAL_APP_ENV="$APPSIGNAL_APP_ENV"
export VITE_PWD="$PWD"
export VITE_HOSTNAME="$(hostname)"

echo "Starting app"
npm run dev
